{
  "name": "mb-assignment",
  "version": "1.0.0",
  "description": "Production-style Playwright framework for the MultiBank QA automation take-home.",
  "private": true,
  "scripts": {
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check .",
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:ui",
    "test:ui": "playwright test tests/ui",
    "test:ui:smoke": "playwright test tests/ui --grep @smoke",
    "test:unit": "playwright test tests/unit",
    "report:open": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "automation"
  ],
  "author": "Samarth",
  "license": "MIT",
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
